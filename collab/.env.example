# Collab service env — Hocuspocus listens here, talks to the FastAPI backend.

HOCUSPOCUS_PORT=1234

# Postgres connection to the SAME Supabase project the backend writes through.
# Free-tier projects no longer expose IPv4 on db.<project>.supabase.co —
# use the Session pooler (port 5432) for a long-running Node process, or the
# Transaction pooler (port 6543) if running serverless.
#
# Grab this from Supabase Dashboard → Project Settings → Database →
# "Connection string" → "Session pooler". Replace [YOUR-PASSWORD] and
# <project-ref> / <region> with the values shown there.
DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# FastAPI internal endpoints. Match the running uvicorn host/port.
BACKEND_AUTHORIZE_URL=http://localhost:8000/internal/collab/authorize
BACKEND_CHANGED_URL=http://localhost:8000/internal/collab/changed
BACKEND_SEED_URL=http://localhost:8000/internal/collab/seed

# Must equal COLLAB_SHARED_SECRET in backend/.env. Rotate together.
BACKEND_SHARED_SECRET=change-me

# Materializer idle window — ms of no Yjs changes before the backend flushes
# the doc to relational tables. Production: 30000 (30s). Dev: 3000-5000 for
# fast feedback when verifying the materializer.
YJS_IDLE_MS=30000
