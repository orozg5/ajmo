SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=  # Only needed for legacy HS256 local dev setups; hosted Supabase (ES256) uses JWKS — leave blank

TAVILY_API_KEY=

# ─── AI provider routing (per feature, required) ────────────────────────────
# Comma-separated provider list per feature. Each provider is tried in order
# on quota errors. Default: gemini primary with groq as quota fallback —
# enrichment latency on a local Ollama 4B model dwarfs the click-to-add wait,
# so cloud LLMs are the dev default and Ollama is an opt-in offline mode
# (set both chains to `ollama` to use it).
# Cross-city transport does not use an LLM — it goes through OSRM (drive),
# Transitous (train/bus/ferry), and a haversine flight estimator.
AI_PROVIDER_CHAIN_ENRICH=gemini,groq
AI_PROVIDER_CHAIN_SUGGESTIONS=gemini,groq

# ─── Ollama (local, dev) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nemotron-3-nano:4b
OLLAMA_KEEP_ALIVE=30m      # keep model resident across requests
OLLAMA_NUM_CTX=4096        # context window (smaller = faster)
OLLAMA_REASONING=false     # disable CoT/think tokens on reasoning-capable models
OLLAMA_REPEAT_PENALTY=1.1  # penalize tokens repeated within last 64; 1.0 disables; >1.15 risks suppressing prompt tokens (model substitutes different entity)
#
# Server-side parallelism (set on the `ollama serve` process, NOT in this file —
# `pydantic-settings` won't read it; this comment is documentation only):
#   PowerShell: $env:OLLAMA_NUM_PARALLEL = 4 ; ollama serve
#   bash:       OLLAMA_NUM_PARALLEL=4 ollama serve
# Default 1 means Ollama queues every request behind the previous one. Setting
# 4 lets enrich-batch's 4 cache-miss items run truly in parallel and stops
# /ai/suggestions from blocking behind a background enrichment. Each parallel
# slot reserves VRAM for the loaded model — a 4B model wants ~3-4 GB per slot.

# ─── Gemini (used when listed in a per-feature chain, e.g. prod) ────────────
GOOGLE_API_KEY=
AI_MODEL=gemini-2.0-flash

# ─── Groq (used when listed in a per-feature chain, e.g. prod) ──────────────
GROQ_API_KEY=
FALLBACK_AI_MODEL=llama-3.3-70b-versatile

# ─── External API User-Agent (required) ─────────────────────────────────────
# Sent on every outbound call to keyless community services that require a
# contact User-Agent: Nominatim (geocoding) and Transitous (transit routing).
# Format: "<app-name>/<version> (<contact-email-or-url>)".
# Nominatim: 1 req/s rate-limited at runtime.
GEOCODER_USER_AGENT=ajmo-dev/contact@example.com

# ─── Image source (Pexels, required) ────────────────────────────────────────
# Single image source for all places. Free tier — get a key at
# https://www.pexels.com/api/. No fallback API; null image is acceptable.
PEXELS_API_KEY=

CORS_ORIGINS=["http://localhost:3000"]  # required — JSON array of allowed origins; add more for production

# ─── Collab service (Hocuspocus → FastAPI bridge) ────────────────────────────
# Shared secret sent on every internal call from collab/ to /internal/collab/*
# Match the same value in collab/.env (BACKEND_SHARED_SECRET).
COLLAB_SHARED_SECRET=
# Materializer idle window — ms of no Yjs changes before flushing the Y.Doc to
# relational tables. Production: 30000 (30s). Dev: 3000-5000 for fast feedback.
YJS_IDLE_MS=30000
