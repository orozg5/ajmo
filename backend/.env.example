SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=  # Only needed for legacy HS256 local dev setups; hosted Supabase (ES256) uses JWKS — leave blank

TAVILY_API_KEY=

AI_PROVIDER_CHAIN=ollama,gemini,groq   # comma-separated provider order
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nemotron-3-nano:4b

# Gemini (used when in AI_PROVIDER_CHAIN)
GOOGLE_API_KEY=
AI_MODEL=gemini-2.0-flash

# Groq (used when in AI_PROVIDER_CHAIN)
GROQ_API_KEY=
FALLBACK_AI_MODEL=llama-3.3-70b-versatile

CORS_ORIGINS=["http://localhost:3000"]  # required — JSON array of allowed origins; add more for production
