SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

TAVILY_API_KEY=

GOOGLE_API_KEY=        # required — primary LLM (Gemini)
AI_MODEL=              # required — e.g. gemini-2.0-flash
GROQ_API_KEY=          # optional — Groq fallback when Gemini quota exhausted (free at console.groq.com)
FALLBACK_AI_MODEL=     # optional — e.g. llama-3.3-70b-versatile

CORS_ORIGINS=["http://localhost:3000"]  # required — JSON array of allowed origins; add more for production