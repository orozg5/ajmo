SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=  # Only needed for legacy HS256 local dev setups; hosted Supabase (ES256) uses JWKS — leave blank

TAVILY_API_KEY=

# ─── AI provider routing (per feature, required) ────────────────────────────
# Comma-separated provider list per feature. Each provider is tried in order
# on quota errors. Dev default: single-provider ollama (fastest, no network).
# Prod: flip to e.g. gemini,groq or groq,gemini.
# Recommended prod transport chain: groq,gemini — Groq's llama-3.1-8b-instant
# returns the tiny per-pair structured output in ~100-200ms, Gemini Flash is
# the quota fallback. Transport is latency-sensitive, so put the fastest first.
AI_PROVIDER_CHAIN_ENRICH=ollama
AI_PROVIDER_CHAIN_SUGGESTIONS=ollama
AI_PROVIDER_CHAIN_TRANSPORT=ollama

# ─── Ollama (local, dev) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nemotron-3-nano:4b
OLLAMA_KEEP_ALIVE=30m      # keep model resident across requests
OLLAMA_NUM_CTX=4096        # context window (smaller = faster)
OLLAMA_REASONING=false     # disable CoT/think tokens on reasoning-capable models

# ─── Gemini (used when listed in a per-feature chain, e.g. prod) ────────────
GOOGLE_API_KEY=
AI_MODEL=gemini-2.0-flash

# ─── Groq (used when listed in a per-feature chain, e.g. prod) ──────────────
GROQ_API_KEY=
FALLBACK_AI_MODEL=llama-3.3-70b-versatile

# ─── Geocoding (keyless OSM stack, required) ────────────────────────────────
# Primary + fallback geocoders. Photon (photon.komoot.io) has no hard rate
# limit; Nominatim (nominatim.openstreetmap.org) is 1 req/s and requires a
# descriptive User-Agent. Set GEOCODER_FALLBACK to the empty string to disable.
GEOCODER_PRIMARY=photon
GEOCODER_FALLBACK=nominatim
GEOCODER_USER_AGENT=ajmo-dev/contact@example.com

CORS_ORIGINS=["http://localhost:3000"]  # required — JSON array of allowed origins; add more for production
